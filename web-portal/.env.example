# BorrowIT web portal database connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=borrowit_user
DB_PASSWORD=secret_password
DB_NAME=borrowit
DB_CONNECTION_LIMIT=20

# Security - Session Management
SESSION_SECRET=change_this_to_a_strong_random_secret_at_least_32_characters_long
SESSION_MAX_AGE=1800000

# Security - Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Security - Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=

# Email delivery placeholders for production verification/reset links
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=BorrowIT <no-reply@borrowit.local>
